# Database (Supabase PostgreSQL)
DB_HOST=db.YOUR_PROJECT.supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT
DB_PASSWORD=your_db_password_here
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Google Maps (restrict key in Cloud Console to your domains)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_MAP_ID=your_map_id_here

# Anthropic (for AI verification and chat)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CORS (comma-separated origins, defaults to localhost)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
