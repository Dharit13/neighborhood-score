# ──────────────────────────────────────────────────────────
# Database (Supabase PostgreSQL) — REQUIRED
# Create a project at https://supabase.com
# Find credentials: Settings → Database → Connection string
# ──────────────────────────────────────────────────────────
DB_HOST=db.YOUR_PROJECT.supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT
DB_PASSWORD=your_db_password_here
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# ──────────────────────────────────────────────────────────
# Google Maps — REQUIRED for geocoding and map display
# Get a key: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Geocoding API, Places API
# Restrict the key to your domains in Cloud Console
# ──────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_MAP_ID=your_map_id_here

# ──────────────────────────────────────────────────────────
# Anthropic — REQUIRED for AI chat, reports, claim verification
# Get a key: https://console.anthropic.com/settings/keys
# ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ──────────────────────────────────────────────────────────
# CORS — OPTIONAL (defaults to localhost:5173,localhost:3000)
# Comma-separated origins for frontend dev servers
# ──────────────────────────────────────────────────────────
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
